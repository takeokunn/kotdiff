{
  "name": "kotdiff",
  "version": "1.4.0",
  "private": true,
  "scripts": {
    "build:content": "esbuild src/content.ts --bundle --outfile=dist/content.js --format=iife",
    "build:background": "esbuild src/background.ts --bundle --outfile=dist/background.js --format=iife",
    "build:dashboard": "esbuild src/dashboard/index.tsx --bundle --outfile=dist/dashboard.js --format=iife --jsx=automatic --jsx-import-source=react && tailwindcss -i src/dashboard/styles.css -o dist/dashboard.css",
    "build:assets": "cp manifest.json dist/ && cp -r icons dist/ && cp src/dashboard/dashboard.html dist/",
    "build": "pnpm run build:content && pnpm run build:background && pnpm run build:dashboard && pnpm run build:assets",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint src/",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/",
    "verify": "pnpm run fmt:check && pnpm run lint && pnpm run test:run",
    "package:chrome": "cd dist && zip -r ../kotdiff-chrome-v${VERSION:?}.zip .",
    "package:firefox": "cd dist && zip -r ../kotdiff-firefox-v${VERSION:?}.xpi .",
    "package:source": "git archive -o kotdiff-source-v${VERSION:?}.zip HEAD",
    "package:local": "pnpm run build && cd dist && zip -r ../kotdiff-chrome-local.zip . && zip -r ../kotdiff-firefox-local.xpi ."
  },
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.36",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.3",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  }
}
